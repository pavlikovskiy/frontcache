<?xml version="1.0" encoding="UTF-8" ?>

<!-- 
this config the same as in logback.xml in classpath. Use this one if you want to override default configuration. 
uncomment it in frontcache.properties:

front-cache.request-logs-config=fc-logback.xml
-->
<configuration>
    
    <!-- ReguestLoggerFile for REQUEST LOGS ONLY -->
	<appender name="ReguestLoggerFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<filter class="ch.qos.logback.classic.filter.LevelFilter">
			<level>TRACE</level>
			<OnMatch>NEUTRAL</OnMatch>
			<OnMismatch>DENY</OnMismatch>
		</filter>

		<File>${frontcache.home}/logs/frontcache-requests.log</File>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<FileNamePattern>${frontcache.home}/logs/frontcache-requests-%d{yyyy-MM-dd}.log.zip</FileNamePattern>
		</rollingPolicy>
		<layout class="ch.qos.logback.classic.PatternLayout">
			  <Pattern>%msg%n</Pattern>
		</layout>
	</appender>
	
    <!-- FailedRequestLoggerFile for NON-SUCCESSFUL REQUEST LOGS ONLY (short-circuited/timeout/rejected/bad-request/failure) -->
	<appender name="FailedRequestLoggerFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<filter class="ch.qos.logback.classic.filter.LevelFilter">
			<level>TRACE</level>
			<OnMatch>NEUTRAL</OnMatch>
			<OnMismatch>DENY</OnMismatch>
		</filter>

		<File>${frontcache.home}/logs/frontcache-failed-requests.log</File>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<FileNamePattern>${frontcache.home}/logs/frontcache-failed-requests-%d{yyyy-MM-dd}.log.zip</FileNamePattern>
		</rollingPolicy>
		<layout class="ch.qos.logback.classic.PatternLayout">
			  <Pattern>%msg%n</Pattern>
		</layout>
	</appender>

	<appender name="Error" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<filter class="ch.qos.logback.classic.filter.LevelFilter">
			<level>ERROR</level>
			<OnMatch>NEUTRAL</OnMatch>
			<OnMismatch>DENY</OnMismatch>
		</filter>

		<File>${frontcache.home}/logs/error.log</File>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<FileNamePattern>${frontcache.home}/logs/error-%d{yyyy-MM-dd}.log.zip</FileNamePattern>
		</rollingPolicy>
		<layout class="ch.qos.logback.classic.PatternLayout">
			  <Pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</Pattern>
		</layout>
	</appender>
		
	<appender name="Info" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<filter class="ch.qos.logback.classic.filter.LevelFilter">
			<level>INFO</level>
			<OnMatch>NEUTRAL</OnMatch>
			<OnMismatch>DENY</OnMismatch>
		</filter>
		<File>${frontcache.home}/logs/info.log</File>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<FileNamePattern>${frontcache.home}/logs/info-%d{yyyy-MM-dd}.log.zip</FileNamePattern>
		</rollingPolicy>
		<layout class="ch.qos.logback.classic.PatternLayout">
             <Pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</Pattern>
		</layout>
	</appender>	
		
	
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <layout class="ch.qos.logback.classic.PatternLayout">
      <Pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</Pattern>
    </layout>
  </appender>



	<root>
		<appender-ref ref="Error" />
		<appender-ref ref="Info" />	
		<appender-ref ref="STDOUT" />
	</root>

	<!-- for request logger -->
	<logger name="org.frontcache.reqlog.RequestLogger">
	    <level value="TRACE" />
		<appender-ref ref="ReguestLoggerFile" />
	</logger>

	<!-- for non-successful requests only (additivity=false -> kept out of the root/info logs) -->
	<logger name="frontcache.failed-requests" additivity="false">
	    <level value="TRACE" />
		<appender-ref ref="FailedRequestLoggerFile" />
	</logger>


</configuration>